datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Wallet {
  id        String   @id @default(uuid())
  name      String
  balance   Float    @default(0)
  type      String   // "debit", "cash", "ewallet", "investment"
  icon      String?  // optionally store icon name or color
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionsFrom Transaction[] @relation("WalletTransactions")
  transactionsTo   Transaction[] @relation("WalletTransfers")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String   // "income", "expense"
  icon      String?
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(uuid())
  type        String   // "income", "expense", "transfer"
  amount      Float
  date        DateTime @default(now())
  note        String?
  
  // For Income/Expense/Transfer (Source)
  walletId    String
  wallet      Wallet   @relation("WalletTransactions", fields: [walletId], references: [id])
  
  // For Transfer Destination
  toWalletId  String?
  toWallet    Wallet?  @relation("WalletTransfers", fields: [toWalletId], references: [id])

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
